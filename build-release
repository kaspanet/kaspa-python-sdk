#!/bin/bash

set -e

VENV_DIR="env"

if [ ! -d "$VENV_DIR" ]; then
    echo "Creating virtual environment in '$VENV_DIR'"
    python3 -m venv $VENV_DIR
else
    echo "Virtual environment already exists, using '$VENV_DIR'"
fi

echo "Activating virtual environment '$VENV_DIR'"
source $VENV_DIR/bin/activate

if ! command -v maturin &> /dev/null; then
    echo "Maturin not found in '$VENV_DIR', installing..."
    pip install maturin
else
    echo "Maturin is already installed (in '$VENV_DIR'). Installed version is:"
    maturin --version
fi

STUB_COMMAND="cargo run --bin stub-gen --release"
echo "Generating stub file (.pyi) with command: '$STUB_COMMAND'"
$STUB_COMMAND

# Build the kaspa.silverscript extension module (a separate workspace member)
# and inject its .so into the python-source tree so maturin bundles it under 
# kaspa/silverscript/.
echo "Building kaspa.silverscript extension module"
if [ "$(uname)" = "Darwin" ]; then
    SS_RUSTFLAGS="-C link-arg=-undefined -C link-arg=dynamic_lookup"
    SS_DYLIB="target/release/libsilverscript.dylib"
else
    SS_RUSTFLAGS=""
    SS_DYLIB="target/release/libsilverscript.so"
fi
RUSTFLAGS="$SS_RUSTFLAGS" cargo build --release -p kaspa-silverscript --lib --target-dir target
SS_SUFFIX=$(python -c "import importlib.machinery as m; print(m.EXTENSION_SUFFIXES[0])")
mkdir -p python/kaspa/silverscript
cp "$SS_DYLIB" "python/kaspa/silverscript/silverscript${SS_SUFFIX}"

# Generate kaspa.silverscript type stubs -> python/kaspa/silverscript/__init__.pyi.
# Built in an isolated target dir to avoid overwriting the main build cache.
echo "Generating kaspa.silverscript stub file"
cargo run --release -p kaspa-silverscript --bin stub-gen --no-default-features --target-dir target/silverscript-stubgen

BUILD_CMD="maturin build --release --strip --sdist --target-dir target --out target/wheels"
echo "Building Python package with command: '$BUILD_CMD'"
$BUILD_CMD

echo "Build complete."
